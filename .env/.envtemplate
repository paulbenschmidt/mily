# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True

# Logging
LOGGER_LOG_LEVEL="DEBUG"

# Neon Database Configuration
DATABASE_NAME=your-database-name
DATABASE_USER=your-database-user
DATABASE_PASSWORD=your-database-password
DATABASE_HOST=your-neon-host.neon.tech
DATABASE_PORT=5432

# API
NEXT_PUBLIC_API_URL=http://localhost:8000/api
FRONTEND_URL=https://your-vercel-app.vercel.app

# Security
ALLOWED_HOSTS=https://your-vercel-app.vercel.app,https://*.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-vercel-app.vercel.app,https://*.vercel.app
CORS_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,https://*.vercel.app

# Email Service
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=None
EMAIL_HOST_PASSWORD=None
DEFAULT_FROM_EMAIL=noreply_ENVIRONMENT@mily.bio

# Users
SUPERUSER_EMAIL=
SUPERUSER_PASSWORD=
