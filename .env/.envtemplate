########################
###     Backend      ###
########################

# Django Settings
SECRET_KEY=
DEBUG=True

# Logging
LOGGER_LOG_LEVEL="DEBUG"

# Neon Database Configuration
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=
DATABASE_PORT=5432

# Users
SUPERUSER_EMAIL=
SUPERUSER_PASSWORD=
TESTUSER_EMAIL=
TESTRUSER_PASSWORD=

# Backend awareness of frontend for URLs
FRONTEND_URL=http://localhost:3000

# Security
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# Cookie Settings
SESSION_COOKIE_SECURE=False  # Set to True in production (HTTPS only)
SESSION_COOKIE_DOMAIN=.localhost # Set to .mily.bio for production

# Email Service (Resend)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend  # Use console for local dev
RESEND_API_KEY=abc  # When defined, emails will be sent via Resend API
DEFAULT_FROM_EMAIL=noreply@verify.mily.bio

#########################
###     Frontend      ###
#########################

# API
NEXT_PUBLIC_API_URL=http://localhost:8000/api
